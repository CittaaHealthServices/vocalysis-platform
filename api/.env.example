# ═══════════════════════════════════════════════════════════
# VOCALYSIS API — Environment Variables
# Copy to .env and fill all values before running locally
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# Server
NODE_ENV=production
PORT=3001

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vocalysis?retryWrites=true&w=majority

# Redis (Railway provides this automatically in production)
REDIS_URL=redis://localhost:6379

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_KEY

# VocaCore™ Engine (Internal — never expose publicly)
VOCOCORE_SERVICE_URL=http://localhost:5001
VOCOCORE_INTERNAL_KEY=REPLACE_WITH_SHARED_SECRET_32_CHARS
# Gemini fallback (used only if VocoCore Python service is unreachable)
VOCOCORE_INFERENCE_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# ElevenLabs — Indian voice generation for ML model retraining
# Activate Multilingual v2 TTS on your ElevenLabs account
# Set in Railway env vars; triggers POST /retrain on VocoCore service
ELEVENLABS_API_KEY=REPLACE_WITH_ELEVENLABS_API_KEY

# Frontend
CLIENT_URL=https://vocalysis.cittaa.in
CORS_ALLOWED_ORIGINS=https://vocalysis.cittaa.in,http://localhost:5173

# File Storage
STORAGE_TYPE=railway_volume
STORAGE_PATH=/app/storage

# Email (use Gmail SMTP or Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cittaa.in
SMTP_PASS=REPLACE_WITH_APP_PASSWORD
EMAIL_FROM=noreply@vocalysis.cittaa.in
ALERT_EMAIL_TO=sairam@cittaa.in,rohan@cittaa.in

# Google OAuth (for Calendar + Meet integration)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://api.vocalysis.cittaa.in/auth/google/callback

# Security
SUPER_ADMIN_IP_WHITELIST=
BULL_BOARD_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# API
API_VERSION=1
LOG_LEVEL=info
